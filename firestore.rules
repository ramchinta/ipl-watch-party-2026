rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isAdmin() { return isAuthenticated() && request.auth.token.role == 'admin'; }
    function isHost() { return isAuthenticated() && request.auth.token.role == 'host'; }
    function isPartyHost(partyId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/watchParties/$(partyId)).data.hostId == request.auth.uid;
    }

    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Only admin can write matches (powerplay, results, windows)
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /watchParties/{partyId} {
      allow read: if isAuthenticated();
      allow create: if isHost();
      allow update: if isAuthenticated() || isAdmin() || isPartyHost(partyId);
      allow delete: if isAdmin() || isPartyHost(partyId);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /predictions/{predId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        resource.data.locked == false;
      allow delete: if isAdmin();
    }

    match /scores/{scoreId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isHost() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /leaderboards/{partyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Over questions — admin manages state and results
    match /overQuestions/{qId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Over guesses — users submit their own guesses
    match /overGuesses/{guessId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }
  }
}
