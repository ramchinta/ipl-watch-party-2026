# Copy this to .env.local and fill in your Firebase project values
# Get these from: Firebase Console → Project Settings → Your Apps → Web App

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Your deployed app URL (used for QR codes and share links)
# During development this is automatically window.location.origin
VITE_APP_URL=https://your-project-id.web.app

# Set to 'true' to use Firebase local emulators instead of production
VITE_USE_EMULATORS=false
